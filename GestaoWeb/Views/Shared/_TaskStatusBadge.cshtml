@model GestaoWeb.Models.Domain.WorkTaskStatus
@{
    var (css, label) = Model switch
    {
        GestaoWeb.Models.Domain.WorkTaskStatus.Pending    => ("uk-label-warning", "Pendente"),
        GestaoWeb.Models.Domain.WorkTaskStatus.InProgress => ("",                 "Em andamento"),
        GestaoWeb.Models.Domain.WorkTaskStatus.Completed  => ("uk-label-success", "Concluída"),
        _ => ("", Model.ToString())
    };
}
<span class="uk-label @css">@label</span>
