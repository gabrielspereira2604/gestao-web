@inject Microsoft.AspNetCore.Identity.UserManager<GestaoWeb.Models.Domain.AppUser> UserManager
@{
    ViewData["Title"] = "Início";
    var homeUser = User.Identity?.IsAuthenticated == true ? await UserManager.GetUserAsync(User) : null;
    bool homeIsManager = homeUser?.IsManager == true;
}

<h1 class="uk-heading-small uk-margin-bottom">Bem-vindo ao GestaoWeb</h1>

<div class="uk-grid-match @(homeIsManager ? "uk-child-width-1-2@m" : "")" uk-grid>
    <div>
        <div class="uk-card uk-card-default uk-card-body uk-card-hover">
            <h3 class="uk-card-title"><span uk-icon="icon: list; ratio: 1.2" class="uk-margin-small-right"></span>Tarefas</h3>
            <p>Visualize e gerencie as tarefas atribuídas ou criadas por você.</p>
            <a asp-controller="Tasks" asp-action="Index" class="uk-button uk-button-primary">Ver tarefas</a>
        </div>
    </div>
    @if (homeIsManager)
    {
        <div>
            <div class="uk-card uk-card-default uk-card-body uk-card-hover">
                <h3 class="uk-card-title"><span uk-icon="icon: users; ratio: 1.2" class="uk-margin-small-right"></span>Usuários</h3>
                <p>Cadastre e gerencie os usuários do sistema.</p>
                <a asp-controller="Users" asp-action="Index" class="uk-button uk-button-default">Ver usuários</a>
            </div>
        </div>
    }
</div>
