@model IEnumerable<GestaoWeb.Models.Domain.TaskItem>
@{
    ViewData["Title"] = "Tarefas";
    bool isManager = ViewBag.IsManager == true;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Tarefas</h2>
    @if (isManager)
    {
        <a asp-action="Create" class="btn btn-primary">Nova tarefa</a>
    }
</div>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @msg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <p class="text-muted">Nenhuma tarefa encontrada.</p>
}
else
{
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Descrição</th>
                @if (isManager)
                {
                    <th>Responsável</th>
                }
                else
                {
                    <th>Criada por</th>
                }
                <th>Data limite</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var task in Model)
            {
                <tr>
                    <td>@task.Description</td>
                    <td>@(isManager ? task.AssignedTo.FullName : task.CreatedBy.FullName)</td>
                    <td>
                        @{
                            bool overdue = task.DueDate < DateTime.Now && task.Status != GestaoWeb.Models.Domain.WorkTaskStatus.Completed;
                        }
                        <span class="@(overdue ? "text-danger fw-semibold" : "")">
                            @task.DueDate.ToString("dd/MM/yyyy HH:mm")
                        </span>
                    </td>
                    <td>@Html.Partial("_TaskStatusBadge", task.Status)</td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@task.Id" class="btn btn-sm btn-outline-secondary">Detalhes</a>
                        @if (!isManager && task.Status != GestaoWeb.Models.Domain.WorkTaskStatus.Completed)
                        {
                            <a asp-action="Edit" asp-route-id="@task.Id" class="btn btn-sm btn-outline-primary">Atualizar</a>
                        }
                        @if (isManager)
                        {
                            <a asp-action="Edit" asp-route-id="@task.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
