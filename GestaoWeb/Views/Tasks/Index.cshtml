@model IEnumerable<GestaoWeb.Models.Domain.TaskItem>
@{
    ViewData["Title"] = "Tarefas";
    bool isManager = ViewBag.IsManager == true;
}

<div class="uk-flex uk-flex-between uk-flex-middle uk-margin-bottom">
    <h2 class="uk-heading-small uk-margin-remove">Tarefas</h2>
    @if (isManager)
    {
        <a asp-action="Create" class="uk-button uk-button-primary">
            <span uk-icon="icon: plus; ratio: 0.9"></span> Nova tarefa
        </a>
    }
</div>

@if (TempData["Success"] is string msg)
{
    <div class="uk-alert-success uk-margin-bottom" uk-alert>
        <button class="uk-alert-close" uk-close></button>
        <p>@msg</p>
    </div>
}

@if (!Model.Any())
{
    <div class="uk-alert-primary" uk-alert>
        <p>Nenhuma tarefa encontrada.</p>
    </div>
}
else
{
    <div class="uk-overflow-auto">
        <table class="uk-table uk-table-hover uk-table-middle uk-table-divider">
            <thead>
                <tr>
                    <th>@(isManager ? "Responsável" : "Criada por")</th>
                    <th>Data limite</th>
                    <th class="uk-table-shrink">Status</th>
                    <th class="uk-table-shrink"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var task in Model)
                {
                    <tr>
                        <td>@(isManager ? task.AssignedTo.FullName : task.CreatedBy.FullName)</td>
                        <td>
                            @{
                                bool overdue = task.DueDate < DateOnly.FromDateTime(DateTime.Today)
                                    && task.Status != GestaoWeb.Models.Domain.WorkTaskStatus.Completed;
                            }
                            <span class="@(overdue ? "uk-text-danger uk-text-bold" : "")">
                                @task.DueDate.ToString("dd/MM/yyyy")
                            </span>
                        </td>
                        <td class="uk-text-nowrap">@Html.Partial("_TaskStatusBadge", task.Status)</td>
                        <td class="uk-text-nowrap">
                            <a asp-action="Details" asp-route-id="@task.Id"
                               class="uk-button uk-button-default uk-button-small">Detalhes</a>
                            @if (isManager || task.Status != GestaoWeb.Models.Domain.WorkTaskStatus.Completed)
                            {
                                <a asp-action="Edit" asp-route-id="@task.Id"
                                   class="uk-button uk-button-primary uk-button-small">
                                    @(isManager ? "Editar" : "Atualizar")
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
