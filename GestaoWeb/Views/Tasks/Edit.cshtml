@model GestaoWeb.Models.ViewModels.Tasks.EditTaskStatusViewModel
@{
    ViewData["Title"] = "Atualizar tarefa";
    bool isManager = ViewBag.IsManager == true;
}

<h2 class="uk-heading-small uk-margin-bottom">@(isManager ? "Editar tarefa" : "Atualizar status")</h2>

<div class="uk-card uk-card-default uk-card-body uk-box-shadow-small" style="max-width:520px;">
    <dl class="uk-description-list uk-description-list-divider uk-margin-bottom">
        <dt>Descrição</dt>
        <dd>@Model.Description</dd>
        <dt>Responsável</dt>
        <dd>@Model.AssignedToName</dd>
        <dt>Criada por</dt>
        <dd>@Model.CreatedByName</dd>
        <dt>Data limite</dt>
        <dd>@Model.DueDate.ToString("dd/MM/yyyy HH:mm")</dd>
    </dl>

    <form asp-action="Edit" method="post" class="uk-form-stacked">
        <input asp-for="Id" type="hidden" />
        <input asp-for="Description" type="hidden" />
        <input asp-for="DueDate" type="hidden" />
        <input asp-for="AssignedToName" type="hidden" />
        <input asp-for="CreatedByName" type="hidden" />

        <div asp-validation-summary="ModelOnly" class="uk-alert-danger uk-margin-bottom" uk-alert>
            <button class="uk-alert-close" uk-close></button>
        </div>

        <div class="uk-margin">
            <label asp-for="Status" class="uk-form-label uk-text-bold"></label>
            <div class="uk-form-controls">
                <select asp-for="Status" asp-items="ViewBag.AvailableStatuses" class="uk-select"></select>
                <span asp-validation-for="Status" class="uk-text-danger uk-text-small"></span>
            </div>
        </div>

        <div class="uk-flex uk-flex-left" style="gap:8px;">
            <button type="submit" class="uk-button uk-button-primary">Salvar</button>
            <a asp-action="Index" class="uk-button uk-button-default">Cancelar</a>
        </div>
    </form>
</div>
