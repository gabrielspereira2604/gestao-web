@model GestaoWeb.Models.Domain.TaskItem
@{
    ViewData["Title"] = "Detalhes da tarefa";
    bool isManager = ViewBag.IsManager == true;
}

<div class="uk-flex uk-flex-between uk-flex-middle uk-margin-bottom">
    <h2 class="uk-heading-small uk-margin-remove">Detalhes da tarefa</h2>
    <div class="uk-flex" style="gap:8px;">
        @if (isManager || Model.Status != GestaoWeb.Models.Domain.WorkTaskStatus.Completed)
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="uk-button uk-button-primary uk-button-small">
                @(isManager ? "Editar" : "Atualizar status")
            </a>
        }
        <a asp-action="Index" class="uk-button uk-button-default uk-button-small">Voltar</a>
    </div>
</div>

<div class="uk-card uk-card-default uk-card-body uk-box-shadow-small" style="max-width:540px;">
    <div class="uk-margin-bottom">
        @Html.Partial("_TaskStatusBadge", Model.Status)
    </div>

    <dl class="uk-description-list uk-description-list-divider">
        <dt>Descrição</dt>
        <dd>@Model.Description</dd>
        <dt>Responsável</dt>
        <dd>@Model.AssignedTo.FullName</dd>
        <dt>Criada por</dt>
        <dd>@Model.CreatedBy.FullName</dd>
        <dt>Data limite</dt>
        <dd>
            @{
                bool overdue = Model.DueDate < DateOnly.FromDateTime(DateTime.Today)
                    && Model.Status != GestaoWeb.Models.Domain.WorkTaskStatus.Completed;
            }
            <span class="@(overdue ? "uk-text-danger uk-text-bold" : "")">
                @Model.DueDate.ToString("dd/MM/yyyy")
            </span>
        </dd>
        <dt>Criada em</dt>
        <dd>@Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
        @if (Model.CompletedAt.HasValue)
        {
            <dt>Concluída em</dt>
            <dd>@Model.CompletedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
        }
    </dl>
</div>
