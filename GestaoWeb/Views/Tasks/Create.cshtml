@model GestaoWeb.Models.ViewModels.Tasks.CreateTaskViewModel
@{
    ViewData["Title"] = "Nova tarefa";
}

<h2 class="mb-4">Nova tarefa</h2>

<div class="card shadow-sm" style="max-width:520px;">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

            <div class="mb-3">
                <label asp-for="AssignedToId" class="form-label"></label>
                <select asp-for="AssignedToId" asp-items="ViewBag.Subordinates" class="form-select">
                    <option value="">-- Selecione o responsável --</option>
                </select>
                <span asp-validation-for="AssignedToId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DueDate" class="form-label"></label>
                <input asp-for="DueDate" class="form-control" type="datetime-local" />
                <span asp-validation-for="DueDate" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Criar tarefa</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
