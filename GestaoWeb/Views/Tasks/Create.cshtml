@model GestaoWeb.Models.ViewModels.Tasks.CreateTaskViewModel
@{
    ViewData["Title"] = "Nova tarefa";
}

<h2 class="uk-heading-small uk-margin-bottom">Nova tarefa</h2>

<div class="uk-card uk-card-default uk-card-body uk-box-shadow-small" style="max-width:520px;">
    <form asp-action="Create" method="post" class="uk-form-stacked">
        <div asp-validation-summary="ModelOnly" class="uk-alert-danger uk-margin-bottom" uk-alert>
            <button class="uk-alert-close" uk-close></button>
        </div>

        <div class="uk-margin">
            <label asp-for="AssignedToId" class="uk-form-label"></label>
            <div class="uk-form-controls">
                <select asp-for="AssignedToId" asp-items="ViewBag.Collaborators" class="uk-select">
                    <option value="">— Selecione o responsável —</option>
                </select>
                <span asp-validation-for="AssignedToId" class="uk-text-danger uk-text-small"></span>
            </div>
        </div>

        <div class="uk-margin">
            <label asp-for="Description" class="uk-form-label"></label>
            <div class="uk-form-controls">
                <textarea asp-for="Description" class="uk-textarea" rows="4"></textarea>
                <span asp-validation-for="Description" class="uk-text-danger uk-text-small"></span>
            </div>
        </div>

        <div class="uk-margin">
            <label asp-for="DueDate" class="uk-form-label"></label>
            <div class="uk-form-controls">
                <input asp-for="DueDate" class="uk-input" type="date" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                <span asp-validation-for="DueDate" class="uk-text-danger uk-text-small"></span>
            </div>
        </div>

        <div class="uk-flex uk-flex-left" style="gap:8px;">
            <button type="submit" class="uk-button uk-button-primary">Criar tarefa</button>
            <a asp-action="Index" class="uk-button uk-button-default">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
