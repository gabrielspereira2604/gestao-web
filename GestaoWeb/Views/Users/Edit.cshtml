@model GestaoWeb.Models.ViewModels.Users.EditUserViewModel
@{
    ViewData["Title"] = "Editar usuário";
    bool isManager = ViewBag.IsManager == true;
}

<h2 class="mb-4">Editar usuário</h2>

<div class="card shadow-sm" style="max-width:600px;">
    <div class="card-body">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

            <input asp-for="Id" type="hidden" />
            <input asp-for="CurrentProfilePhotoPath" type="hidden" />

            <div class="mb-3 text-center">
                @if (!string.IsNullOrEmpty(Model.CurrentProfilePhotoPath))
                {
                    <img src="@Model.CurrentProfilePhotoPath" alt="Foto atual"
                         class="rounded-circle mb-2" width="80" height="80" style="object-fit:cover;" />
                    <br />
                }
                <label asp-for="ProfilePhoto" class="form-label"></label>
                <input asp-for="ProfilePhoto" class="form-control" type="file" accept=".jpg,.jpeg,.png,.gif" />
                <span asp-validation-for="ProfilePhoto" class="text-danger small"></span>
                <div class="form-text">Máximo 2 MB. Deixe em branco para manter a foto atual.</div>
            </div>

            <div class="mb-3">
                <label asp-for="FullName" class="form-label"></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="BirthDate" class="form-label"></label>
                <input asp-for="BirthDate" class="form-control" type="date" />
                <span asp-validation-for="BirthDate" class="text-danger small"></span>
            </div>

            <div class="row">
                <div class="col mb-3">
                    <label asp-for="MobilePhone" class="form-label"></label>
                    <input asp-for="MobilePhone" class="form-control" />
                    <span asp-validation-for="MobilePhone" class="text-danger small"></span>
                </div>
                <div class="col mb-3">
                    <label asp-for="HomePhone" class="form-label"></label>
                    <input asp-for="HomePhone" class="form-control" />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Address" class="form-label"></label>
                <input asp-for="Address" class="form-control" />
                <span asp-validation-for="Address" class="text-danger small"></span>
            </div>

            @if (isManager)
            {
                <div class="mb-3 form-check">
                    <input asp-for="IsManager" class="form-check-input" />
                    <label asp-for="IsManager" class="form-check-label">Perfil de gestor</label>
                </div>
            }
            else
            {
                <input asp-for="IsManager" type="hidden" />
            }

            <hr />
            <p class="text-muted small">Alterar senha (deixe em branco para manter a senha atual)</p>

            <div class="row">
                <div class="col mb-3">
                    <label asp-for="NewPassword" class="form-label"></label>
                    <input asp-for="NewPassword" class="form-control" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>
                <div class="col mb-3">
                    <label asp-for="ConfirmNewPassword" class="form-label"></label>
                    <input asp-for="ConfirmNewPassword" class="form-control" />
                    <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Salvar</button>
                @if (isManager)
                {
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                }
                else
                {
                    <a asp-action="Index" asp-controller="Home" class="btn btn-outline-secondary">Cancelar</a>
                }
            </div>
        </form>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
