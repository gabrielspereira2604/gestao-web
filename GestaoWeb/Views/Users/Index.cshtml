@model IEnumerable<GestaoWeb.Models.Domain.AppUser>
@{
    ViewData["Title"] = "Usuários";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Usuários</h2>
    <a asp-action="Create" class="btn btn-primary">Novo usuário</a>
</div>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @msg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<table class="table table-hover align-middle">
    <thead class="table-light">
        <tr>
            <th>Foto</th>
            <th>Nome</th>
            <th>E-mail</th>
            <th>Papel</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(user.ProfilePhotoPath))
                    {
                        <img src="@user.ProfilePhotoPath" alt="@user.FullName"
                             class="rounded-circle" width="40" height="40" style="object-fit:cover;" />
                    }
                    else
                    {
                        <span class="rounded-circle bg-secondary d-inline-flex align-items-center justify-content-center text-white fw-bold"
                              style="width:40px;height:40px;font-size:14px;">
                            @user.FullName.Substring(0, 1).ToUpper()
                        </span>
                    }
                </td>
                <td>@user.FullName</td>
                <td>@user.Email</td>
                <td>
                    @if (user.IsManager)
                    {
                        <span class="badge bg-primary">Gestor</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Subordinado</span>
                    }
                </td>
                <td class="text-end">
                    <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-sm btn-outline-secondary">Detalhes</a>
                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                </td>
            </tr>
        }
    </tbody>
</table>
