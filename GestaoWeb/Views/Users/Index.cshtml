@model IEnumerable<GestaoWeb.Models.Domain.AppUser>
@{
    ViewData["Title"] = "Usuários";
    var currentUserId = ViewBag.CurrentUserId as string;
}

<div class="uk-flex uk-flex-between uk-flex-middle uk-margin-bottom">
    <h2 class="uk-heading-small uk-margin-remove">Usuários</h2>
    <a asp-action="Create" class="uk-button uk-button-primary">
        <span uk-icon="icon: plus; ratio: 0.9"></span> Novo usuário
    </a>
</div>

@if (TempData["Success"] is string msg)
{
    <div class="uk-alert-success uk-margin-bottom" uk-alert>
        <button class="uk-alert-close" uk-close></button>
        <p>@msg</p>
    </div>
}
@if (TempData["Error"] is string err)
{
    <div class="uk-alert-danger uk-margin-bottom" uk-alert>
        <button class="uk-alert-close" uk-close></button>
        <p>@err</p>
    </div>
}

<div class="uk-overflow-auto">
    <table class="uk-table uk-table-hover uk-table-middle uk-table-divider">
        <thead>
            <tr>
                <th class="uk-table-shrink">Foto</th>
                <th>Nome</th>
                <th>E-mail</th>
                <th class="uk-table-shrink">Papel</th>
                <th class="uk-table-shrink"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrEmpty(user.ProfilePhotoPath))
                        {
                            <img src="@user.ProfilePhotoPath" class="gw-avatar-sm uk-border-circle" alt="@user.FullName" />
                        }
                        else
                        {
                            <span class="gw-avatar-placeholder gw-avatar-sm" style="width:32px;height:32px;font-size:13px;">
                                @user.FullName.Substring(0, 1).ToUpper()
                            </span>
                        }
                    </td>
                    <td>@user.FullName</td>
                    <td>@user.Email</td>
                    <td>
                        @if (user.IsManager)
                        {
                            <span class="uk-label" style="background:#1e87f0;">Gestor</span>
                        }
                        else
                        {
                            <span class="uk-label" style="background:#6c757d;">Colaborador</span>
                        }
                    </td>
                    <td class="uk-text-nowrap">
                        <a asp-action="Details" asp-route-id="@user.Id" class="uk-button uk-button-default uk-button-small">Detalhes</a>
                        <a asp-action="Edit" asp-route-id="@user.Id" class="uk-button uk-button-primary uk-button-small">Editar</a>
                        @if (user.Id != currentUserId)
                        {
                            <button type="button" class="uk-button uk-button-danger uk-button-small"
                                    uk-toggle="target: #modal-delete"
                                    data-id="@user.Id"
                                    data-name="@user.FullName"
                                    onclick="prepareDelete(this)">
                                Excluir
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div id="modal-delete" uk-modal>
    <div class="uk-modal-dialog uk-modal-body">
        <h2 class="uk-modal-title">Confirmar exclusão</h2>
        <p>Tem certeza que deseja excluir <strong id="modal-delete-name"></strong>? Esta ação não pode ser desfeita.</p>
        <form id="modal-delete-form" method="post">
            @Html.AntiForgeryToken()
            <div class="uk-flex uk-flex-right" style="gap:8px;">
                <button type="button" class="uk-button uk-button-default uk-modal-close">Cancelar</button>
                <button type="submit" class="uk-button uk-button-danger">Excluir</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function prepareDelete(btn) {
            document.getElementById('modal-delete-name').textContent = btn.dataset.name;
            document.getElementById('modal-delete-form').action = '/Users/Delete/' + btn.dataset.id;
        }
    </script>
}
