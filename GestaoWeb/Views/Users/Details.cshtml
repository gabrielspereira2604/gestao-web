@model GestaoWeb.Models.Domain.AppUser
@{
    ViewData["Title"] = "Detalhes do usuário";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Detalhes do usuário</h2>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">Editar</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
    </div>
</div>

<div class="card shadow-sm" style="max-width:500px;">
    <div class="card-body">
        <div class="text-center mb-4">
            @if (!string.IsNullOrEmpty(Model.ProfilePhotoPath))
            {
                <img src="@Model.ProfilePhotoPath" alt="@Model.FullName"
                     class="rounded-circle" width="100" height="100" style="object-fit:cover;" />
            }
            else
            {
                <span class="rounded-circle bg-secondary d-inline-flex align-items-center justify-content-center text-white fw-bold"
                      style="width:100px;height:100px;font-size:32px;">
                    @Model.FullName.Substring(0, 1).ToUpper()
                </span>
            }
            <h4 class="mt-3 mb-0">@Model.FullName</h4>
            <span class="badge @(Model.IsManager ? "bg-primary" : "bg-secondary") mt-1">
                @(Model.IsManager ? "Gestor" : "Subordinado")
            </span>
        </div>

        <dl class="row mb-0">
            <dt class="col-sm-4">E-mail</dt>
            <dd class="col-sm-8">@Model.Email</dd>

            <dt class="col-sm-4">Celular</dt>
            <dd class="col-sm-8">@Model.MobilePhone</dd>

            @if (!string.IsNullOrEmpty(Model.HomePhone))
            {
                <dt class="col-sm-4">Telefone fixo</dt>
                <dd class="col-sm-8">@Model.HomePhone</dd>
            }

            <dt class="col-sm-4">Nascimento</dt>
            <dd class="col-sm-8">@Model.BirthDate.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-4">Endereço</dt>
            <dd class="col-sm-8">@Model.Address</dd>
        </dl>
    </div>
</div>
