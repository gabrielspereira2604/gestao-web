@model GestaoWeb.Models.Domain.AppUser
@{
    ViewData["Title"] = "Detalhes do usuário";

    string FormatPhone(string? digits)
    {
        if (string.IsNullOrWhiteSpace(digits)) return "—";
        var d = new string(digits.Where(char.IsDigit).ToArray());
        return d.Length == 11
            ? $"({d[..2]}) {d[2..7]}-{d[7..]}"
            : d.Length == 10
                ? $"({d[..2]}) {d[2..6]}-{d[6..]}"
                : digits;
    }
}

<div class="uk-flex uk-flex-between uk-flex-middle uk-margin-bottom">
    <h2 class="uk-heading-small uk-margin-remove">Detalhes do usuário</h2>
    <div class="uk-flex" style="gap:8px;">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="uk-button uk-button-primary uk-button-small">Editar</a>
        <a asp-action="Index" class="uk-button uk-button-default uk-button-small">Voltar</a>
    </div>
</div>

<div class="uk-card uk-card-default uk-card-body uk-box-shadow-small" style="max-width:480px;">
    <div class="uk-text-center uk-margin-bottom">
        @if (!string.IsNullOrEmpty(Model.ProfilePhotoPath))
        {
            <img src="@Model.ProfilePhotoPath" class="gw-avatar uk-border-circle" alt="@Model.FullName" />
        }
        else
        {
            <span class="gw-avatar-placeholder gw-avatar uk-border-circle" style="font-size:28px;">
                @Model.FullName.Substring(0, 1).ToUpper()
            </span>
        }
        <h3 class="uk-margin-small-top uk-margin-remove-bottom">@Model.FullName</h3>
        @if (Model.IsManager)
        {
            <span class="uk-label" style="background:#1e87f0;">Gestor</span>
        }
        else
        {
            <span class="uk-label" style="background:#6c757d;">Colaborador</span>
        }
    </div>

    <dl class="uk-description-list uk-description-list-divider">
        <dt>E-mail</dt>
        <dd>@Model.Email</dd>
        <dt>Celular</dt>
        <dd>@FormatPhone(Model.MobilePhone)</dd>
        @if (!string.IsNullOrEmpty(Model.HomePhone))
        {
            <dt>Telefone fixo</dt>
            <dd>@FormatPhone(Model.HomePhone)</dd>
        }
        <dt>Nascimento</dt>
        <dd>@Model.BirthDate.ToString("dd/MM/yyyy")</dd>
        <dt>Endereço</dt>
        <dd>@Model.Address</dd>
    </dl>
</div>
