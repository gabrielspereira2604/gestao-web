@model GestaoWeb.Models.ViewModels.Users.CreateUserViewModel
@{
    ViewData["Title"] = "Novo usuário";
}

<h2 class="mb-4">Novo usuário</h2>

<div class="card shadow-sm" style="max-width:600px;">
    <div class="card-body">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

            <div class="mb-3">
                <label asp-for="FullName" class="form-label"></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="row">
                <div class="col mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="col mb-3">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <input asp-for="ConfirmPassword" class="form-control" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="BirthDate" class="form-label"></label>
                <input asp-for="BirthDate" class="form-control" type="date" />
                <span asp-validation-for="BirthDate" class="text-danger small"></span>
            </div>

            <div class="row">
                <div class="col mb-3">
                    <label asp-for="MobilePhone" class="form-label"></label>
                    <input asp-for="MobilePhone" class="form-control" />
                    <span asp-validation-for="MobilePhone" class="text-danger small"></span>
                </div>
                <div class="col mb-3">
                    <label asp-for="HomePhone" class="form-label"></label>
                    <input asp-for="HomePhone" class="form-control" />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Address" class="form-label"></label>
                <input asp-for="Address" class="form-control" />
                <span asp-validation-for="Address" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ProfilePhoto" class="form-label"></label>
                <input asp-for="ProfilePhoto" class="form-control" type="file" accept=".jpg,.jpeg,.png,.gif" />
                <span asp-validation-for="ProfilePhoto" class="text-danger small"></span>
                <div class="form-text">Máximo 2 MB. Formatos: JPG, PNG, GIF.</div>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="IsManager" class="form-check-input" />
                <label asp-for="IsManager" class="form-check-label">Perfil de gestor</label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Criar</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
