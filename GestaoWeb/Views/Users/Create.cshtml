@model GestaoWeb.Models.ViewModels.Users.CreateUserViewModel
@{
    ViewData["Title"] = "Novo usuário";
}

<h2 class="uk-heading-small uk-margin-bottom">Novo usuário</h2>

<div class="uk-card uk-card-default uk-card-body uk-box-shadow-small" style="max-width:580px;">
    <form asp-action="Create" method="post" enctype="multipart/form-data" class="uk-form-stacked">
        <div asp-validation-summary="ModelOnly" class="uk-alert-danger uk-margin-bottom" uk-alert>
            <button class="uk-alert-close" uk-close></button>
        </div>

        <div class="uk-margin">
            <label asp-for="FullName" class="uk-form-label"></label>
            <div class="uk-form-controls">
                <input asp-for="FullName" class="uk-input" />
                <span asp-validation-for="FullName" class="uk-text-danger uk-text-small"></span>
            </div>
        </div>

        <div class="uk-margin">
            <label asp-for="Email" class="uk-form-label"></label>
            <div class="uk-form-controls">
                <input asp-for="Email" class="uk-input" />
                <span asp-validation-for="Email" class="uk-text-danger uk-text-small"></span>
            </div>
        </div>

        <div class="uk-grid-small uk-child-width-1-2" uk-grid>
            <div>
                <label asp-for="Password" class="uk-form-label"></label>
                <input asp-for="Password" class="uk-input" />
                <span asp-validation-for="Password" class="uk-text-danger uk-text-small"></span>
            </div>
            <div>
                <label asp-for="ConfirmPassword" class="uk-form-label"></label>
                <input asp-for="ConfirmPassword" class="uk-input" />
                <span asp-validation-for="ConfirmPassword" class="uk-text-danger uk-text-small"></span>
            </div>
        </div>

        <div class="uk-margin">
            <label asp-for="BirthDate" class="uk-form-label"></label>
            <input asp-for="BirthDate" class="uk-input" type="date" />
            <span asp-validation-for="BirthDate" class="uk-text-danger uk-text-small"></span>
        </div>

        <div class="uk-grid-small uk-child-width-1-2" uk-grid>
            <div>
                <label asp-for="MobilePhone" class="uk-form-label"></label>
                <input asp-for="MobilePhone" class="uk-input" />
                <span asp-validation-for="MobilePhone" class="uk-text-danger uk-text-small"></span>
            </div>
            <div>
                <label asp-for="HomePhone" class="uk-form-label"></label>
                <input asp-for="HomePhone" class="uk-input" />
            </div>
        </div>

        <div class="uk-margin">
            <label asp-for="Address" class="uk-form-label"></label>
            <input asp-for="Address" class="uk-input" />
            <span asp-validation-for="Address" class="uk-text-danger uk-text-small"></span>
        </div>

        <div class="uk-margin">
            <label asp-for="ProfilePhoto" class="uk-form-label"></label>
            <input asp-for="ProfilePhoto" class="uk-input" type="file" accept=".jpg,.jpeg,.png,.gif" />
            <span asp-validation-for="ProfilePhoto" class="uk-text-danger uk-text-small"></span>
            <p class="uk-text-small uk-text-muted uk-margin-remove-top">Máximo 2 MB. JPG, PNG ou GIF.</p>
        </div>

        <div class="uk-margin">
            <label class="uk-flex uk-flex-middle" style="gap:8px;">
                <input asp-for="IsManager" class="uk-checkbox" />
                <span>Perfil de gestor</span>
            </label>
        </div>

        <div class="uk-flex uk-flex-left" style="gap:8px;">
            <button type="submit" class="uk-button uk-button-primary">Criar</button>
            <a asp-action="Index" class="uk-button uk-button-default">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
